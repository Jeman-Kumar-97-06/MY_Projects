<%- include('../partials/top_repeat.ejs')%>

    <!-- The Whole Body -->
    <main class="wrapper">
        <% for( let i = 0; i < all_notes.length; i++ ) { %>
            <div class="each_note_content">
                <h3 class="each_note_content_title"><%= all_notes[i].title %></h3>
                <h4 class="each_note_content_subject"><%= all_notes[i].subject %></h4>
                <p class="each_note_content_content"><%= all_notes[i].body %></p>
                <button>Expand</button>
            </div>
            
        <% } %>
    </main>

<%- include('../partials/bottom_repeat.ejs')%>